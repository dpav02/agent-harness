{
  "$schema": "https://opencode.ai/config.json",
  "model": "dgx/qwen3.6-27b",
  "small_model": "dgx/qwen3.6-27b",
  "instructions": [
    "workflow-agents.md",
    "testing-agents.md",
    "planning-spec-driven.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "provider": {
    "dgx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DGX Spark (Qwen3.6-27B PrismaAURA)",
      "options": {
        "baseURL": "http://edgexpert-84c0:8080/v1",
        "apiKey": "local",
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "qwen3.6-27b": {
          "name": "Qwen3.6-27B PrismaAURA",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  }
}
