{
  "$schema": "https://opencode.ai/config.json",
  // Thinking: sibling model IDs (not Ctrl+t variants — openai-compatible does not
  // reliably forward chat_template_kwargs via variants). Selectable:
  // dsv4-flash-ablit-thinking, ornith-35b-thinking, ornith-heretic-35b-thinking.
  // Implementer: dgx-ornith/* (:8010). Heretic: dgx-ornith-heretic/* (:8011).
  "model": "dgx/dsv4-flash-ablit",
  "small_model": "dgx/dsv4-flash-ablit",
  // 2026-07-06 (davebench forensics): the three instruction files were proven
  // behaviorally inert for qwen3.6-27b at ~2K tokens/step of context cost —
  // slimmed to empty for the local-model daily driver. Restore the list when
  // adding a frontier-model provider (instruction-following models use them).
  // Was: ["workflow-agents.md", "testing-agents.md", "planning-spec-driven.md"]
  "instructions": [],
  "compaction": {
    "auto": true,
    // prune rewrites request history -> breaks vLLM prefix caching -> full
    // re-prefill of a huge context at ~10 tok/s. Keep append-only.
    "prune": false,
    "reserved": 20000
  },
  // Goal system: standardized on /loop-goal (plugins/opencode-loop.ts, auto-loaded
  // from the plugins dir — do not also list @bybrawe/opencode-loop here). opencode-goal
  // (/goal) removed 2026-07-19: its auto-continue-until-complete prompt fights the
  // supervised fail-stop loop these locals need (small-model-prompting.md). Do not
  // re-add. The auto-update plugin lives in the machine-managed opencode.json.
  "plugin": [],
  "provider": {
    "dgx": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DGX Spark (stable :8000 alias -> live backend)",
      "options": {
        "baseURL": "http://edgexpert-84c0:8000/v1",
        "apiKey": "local",
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "dsv4-flash-ablit": {
          "name": "dsv4-flash-ablit (abliterated DSV4 k=5, 1M ctx, MTP n=5, think off)",
          "limit": {
            "context": 1048576,
            "output": 8192
          },
          "options": {
            "chat_template_kwargs": {
              "thinking": false
            }
          }
        },
        "dsv4-flash-ablit-thinking": {
          "name": "dsv4-flash-ablit-thinking (same :8000; think on + reasoning_effort=high)",
          "limit": {
            "context": 1048576,
            "output": 8192
          },
          "options": {
            "chat_template_kwargs": {
              "thinking": true,
              "reasoning_effort": "high"
            }
          }
        },
        "a3b-q8-mtp": {
          "name": "Qwen3.6-35B-A3B Q8+MTP (playoff champ 0.886 @ 85 tok/s) — DOWN until queue-end restore",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    },
    "dgx-glm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DGX Spark Lane B (GLM-5.2 2-bit TP2)",
      "options": {
        "baseURL": "http://spark-3984:8000/v1",
        "apiKey": "local",
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "spark-glm52": {
          "name": "spark-glm52 (GLM-5.2 2-bit pruned-208 TP2 Checkpoint-1, ~15 t/s, 8K ctx) — DOWN",
          "limit": {
            "context": 8192,
            "output": 4096
          }
        }
      }
    },
    "dgx-ornith": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DGX Spark3 Ornith implementer (llama.cpp :8010)",
      "options": {
        "baseURL": "http://spark-3984:8010/v1",
        "apiKey": "local",
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "ornith-35b": {
          "name": "ornith-35b (APEX-I-Quality MTP n=2, 262k ctx, mmproj vision, think off)",
          "limit": {
            "context": 262144,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "options": {
            "chat_template_kwargs": {
              "enable_thinking": false
            }
          }
        },
        "ornith-35b-thinking": {
          "name": "ornith-35b-thinking (same :8010; enable_thinking on)",
          "limit": {
            "context": 262144,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "options": {
            "chat_template_kwargs": {
              "enable_thinking": true
            }
          }
        }
      }
    },
    // 2026-07-19: Ornith×Heretic A/B on spark3 :8011 (131k). Selectable only.
    "dgx-ornith-heretic": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DGX Spark3 Ornith-Heretic (llama.cpp :8011)",
      "options": {
        "baseURL": "http://spark-3984:8011/v1",
        "apiKey": "local",
        "timeout": 600000,
        "chunkTimeout": 120000
      },
      "models": {
        "ornith-heretic-35b": {
          "name": "ornith-heretic-35b (Heretic Trial63 APEX-I-Quality MTP n=2, 131k, mmproj, think off)",
          "limit": {
            "context": 131072,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          }
        },
        "ornith-heretic-35b-thinking": {
          "name": "ornith-heretic-35b-thinking (same :8011; enable_thinking on)",
          "limit": {
            "context": 131072,
            "output": 8192
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "options": {
            "chat_template_kwargs": {
              "enable_thinking": true
            }
          }
        }
      }
    }
  }
}
